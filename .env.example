# ---------- MongoDB ----------
MONGODB_DB=author_platform
MONGODB_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net

# ---------- Cloudflare R2 (S3-compatible) ----------
# Found in Cloudflare dashboard > R2 > Manage API Tokens
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=author-platform-media
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# Public hostname for reading uploaded files back (R2.dev dev URL or your custom domain)
R2_PUBLIC_HOSTNAME=pub-xxxxxxxxxxxx.r2.dev
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxxxxxx.r2.dev

# ---------- Stripe ----------
# From the Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_your-secret-key
# From the Dashboard > Developers > Webhooks, after registering the endpoint
# printed at the end of `npm run dev` setup (see README/CLIENT_SPEC), or via
# `stripe listen --forward-to localhost:3000/api/webhooks/stripe` locally.
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ---------- Resend (purchase confirmation email) ----------
# From resend.com > API Keys
RESEND_API_KEY=re_your-api-key
# Must be on a domain you've verified with Resend, or use their sandbox
# sender (onboarding@resend.dev) for testing without a domain.
RESEND_FROM_EMAIL="Your Name <books@yourdomain.com>"

# ---------- Admin auth ----------
# Admin login itself is stored in the `admins` collection in MongoDB —
# seed it with: npm run seed:admin -- "admin@example.com" "your-password"
# Random long string used to sign admin session JWTs
AUTH_SECRET=replace-with-a-long-random-string

# ---------- Site ----------
NEXT_PUBLIC_SITE_NAME="Your Name"
NEXT_PUBLIC_SITE_URL=http://localhost:3000
